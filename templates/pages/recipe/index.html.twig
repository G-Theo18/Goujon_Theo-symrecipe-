{% extends 'base.html.twig' %}

{% block title %}SymRecipe - Mes recettes{% endblock %}

{% block body %}
    <div class="container mt-4">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        <h1>Mes recettes</h1>

        {% if not recipes.items is same as ([]) %}
            <a href="{{ path('recipe_new') }}" class="btn btn-info">Rajouter une recette</a>
            <table class="table table-hover mt-4">
                <thead>
                    <tr class="table-secondary">
                        <th>Numéro</th>
                        <th>Nom</th>
                        <th>Prix</th>
                        <th>Difficulté</th>
                        <th>Date de création</th>
                        <th>Édition</th>
                        <th>Suppression</th>
                    </tr>
                </thead>
                <tbody>
                    {% for recipe in recipes %}
                        <tr class="table-dark">
                            <th>{{ recipe.id }}</th>
                            <td>{{ recipe.name }}</td>
                            <td>{{ recipe.price ?? 'Non renseigné' }}</td>
                            <td>{{ recipe.difficulty ?? 'Non renseigné' }}</td>
                            <td>{{ recipe.createdAt|date('d/m/Y') }}</td>
                            <td><a href="{{ path('recipe_edit', { id: recipe.id }) }}" class="btn btn-info">Modifier</a></td>
                            <td><a href="{{ path('recipe_remove', { id: recipe.id }) }}" class="btn btn-danger">Supprimer</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div class="d-flex justify-content-center mt-4">
                {{ knp_pagination_render(recipes) }}
            </div>
        {% else %}
            <h4>Il n'y a aucune recette !</h4>
        {% endif %}
    </div>
{% endblock %}